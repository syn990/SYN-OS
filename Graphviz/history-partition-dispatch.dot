digraph partition_dispatch {
  rankdir=TB;
  bgcolor="#000000";
  fontname="monospace";
  node [shape=box, style="rounded,filled", fillcolor="#2c0101", color="#800000", fontcolor="white", fontname="monospace", fontsize=10];
  edge [color="#AAAAAA", fontcolor="white", fontname="monospace", fontsize=9];

  fw [label="firmware detected?\n(/sys/firmware/efi/efivars)", shape=diamond, fillcolor="#400101"];
  uefi [label="UEFI"];
  bios [label="BIOS / legacy"];
  strat_uefi [label="uefi-bootctl\nGPT + systemd-boot"];
  enc [label="Encryption=yes?", shape=diamond, fillcolor="#400101"];
  strat_grub [label="mbr-grub\nMSDOS, separate unencrypted\n/boot, GRUB cryptomount", fillcolor="#4a1414", penwidth=2, color="#d84a3f"];
  strat_syslinux [label="mbr-syslinux\nMSDOS, single partition,\nno encryption path (syslinux\nhas no LUKS support)"];

  fw -> uefi;
  fw -> bios;
  uefi -> strat_uefi;
  bios -> enc;
  enc -> strat_grub [label="yes"];
  enc -> strat_syslinux [label="no"];

  mismatch [shape=note, fillcolor="#1a1608", color="#c0392b", fontcolor="#e0c896",
            label="Explicit (non-auto) PartitionStrat that\ncontradicts detected firmware: hard exit,\nnot a warning. mbr-syslinux + Encryption=yes\nalso hard-fails — syslinux cannot read LUKS\nunder any circumstance."];
  strat_syslinux -> mismatch [style=dashed, color="#c0392b"];
}
