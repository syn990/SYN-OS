digraph session_start {
  rankdir=TB;
  bgcolor="#000000";
  fontname="monospace";
  node [shape=box, style="rounded,filled", fillcolor="#2c0101", color="#800000", fontcolor="white", fontname="monospace", fontsize=10];
  edge [color="#AAAAAA", fontcolor="white", fontname="monospace", fontsize=9];

  subgraph cluster_origin {
    label="SYN-RTOS, 2021-04-04 -> 2022-10-20"; style="rounded"; color="#444444"; fontcolor="white"; bgcolor="#0a0a0a";
    manual [label="user runs: startx", shape=oval, fillcolor="#400101"];
    xinitrc [label=".xinitrc\nxrdb, xmodmap, setxkbmap gb", shape=note, fillcolor="#260101"];
    cleanline [label="openbox-session\n(plain, no exec, no &)", color="#3a8f5a"];
    autostart [label="openbox/autostart\nfeh wallpaper, sleep 2s && tint2,\nxrandr geometry\n(the real session-start file,\ncorrect in every version)", shape=note, fillcolor="#260101", color="#3a8f5a"];
    manual -> xinitrc -> cleanline;
    cleanline -> autostart [style=dashed, color="#3a8f5a", label="  actual daily path"];
  }

  subgraph cluster_tested {
    label="Tested by hand, .zsh_history, 2022-09-17 -> 09-24"; style="rounded"; color="#3a8f5a"; fontcolor="#8fd9ab"; bgcolor="#0a0a0a";
    install [label="pacman -S xcompmgr\nxcompmgr (bare run)", fillcolor="#0e2a18", color="#3a8f5a", fontcolor="#8fd9ab"];
    tuned [label="xcompmgr -c -C -t-5 -l-5\n-r4.2 -o.55\n(shadow, opacity tuned)", fillcolor="#0e2a18", color="#3a8f5a", fontcolor="#8fd9ab"];
    killed [label="pkill xcompmgr\n(same session)", fillcolor="#0e2a18", color="#3a8f5a", fontcolor="#8fd9ab"];
    install -> tuned -> killed;
  }

  subgraph cluster_break {
    label="SYN-RTOS 829dbcd, 2022-10-20, a month later\n\"A few weeks of untracked changes\""; style="dashed,rounded"; color="#665522"; fontcolor="#ccaa66"; bgcolor="#0a0a0a";
    execline [label="exec openbox-session & xcompmgr", fillcolor="#4a0e0e", color="#c0392b"];
    dead [label="xcompmgr: unreachable\n(exec already replaced\nthe shell)", shape=note, fillcolor="#1a1608", color="#8a6a2f", fontcolor="#e0c896"];
    execline -> dead [style=dashed, color="#c0392b"];
  }

  subgraph cluster_carried {
    label="Dormant in an unused launch path,\n2022-10-20 -> 2026-02-08 (751d13a deletes the file)"; style="rounded"; color="#444444"; fontcolor="white"; bgcolor="#0a0a0a";
    ob [label="Openbox session\n(comment claims compositing;\nnever true, but never the\nreal entry point either)"];
  }

  subgraph cluster_greetd {
    label="Attempted, never wired in, 2026-02-23 -> deleted"; style="dashed,rounded"; color="#665522"; fontcolor="#ccaa66"; bgcolor="#0a0a0a";
    login_zsh [label="synos-login.zsh\n'not ready for use!!!'", fillcolor="#1a1608", color="#8a6a2f", fontcolor="#e0c896"];
    greetd_pkgs [label="pacman -S greetd\ngreetd-tuigreet labwc dbus", fillcolor="#1a1608", color="#8a6a2f", fontcolor="#e0c896"];
    greeter_user [label="useradd greeter\n(/sbin/nologin)", fillcolor="#1a1608", color="#8a6a2f", fontcolor="#e0c896"];
    toml [label="/etc/greetd/config.toml\ntuigreet --cmd synos-session", fillcolor="#1a1608", color="#8a6a2f", fontcolor="#e0c896"];
    pam [label="/etc/pam.d/greetd", fillcolor="#1a1608", color="#8a6a2f", fontcolor="#e0c896"];
    never [label="never called from\nsyn-stage1.zsh\ndeleted, unused", shape=note, fillcolor="#1a1608", color="#c0392b", fontcolor="#e0c896"];
    login_zsh -> greetd_pkgs -> greeter_user -> toml -> pam -> never;
  }

  subgraph cluster_current {
    label="Current, 2026-02-08 ->"; style="rounded"; color="#444444"; fontcolor="white"; bgcolor="#0a0a0a";
    autologin [label="getty@tty1.service.d/autologin.conf\nagetty --autologin root", shape=note, fillcolor="#260101"];
    prompt [label="zsh prompt (root, tty1)", shape=oval, fillcolor="#400101"];
    alias_run [label="user types: synos", shape=oval, fillcolor="#400101"];
    alias_def [label="alias synos=\n\"dbus-run-session --\n env XDG_SESSION_TYPE=wayland labwc\"", shape=note, fillcolor="#260101"];
    labwc [label="labwc (Wayland compositor)\nvia D-Bus session"];
    autologin -> prompt -> alias_run -> alias_def -> labwc;
  }

  killed -> execline [label="  a month later,\n  different file", color="#c0392b", fontcolor="#c0392b", style=dashed];
  execline -> ob;
  ob -> autologin [style=dashed, label="  751d13a deletes\n  .xinitrc entirely", color="#d84a3f", fontcolor="#d84a3f"];

  note [shape=note, fillcolor="#1a1608", color="#665522", fontcolor="#ccaa66",
        label="No display manager in any shipped version, either repo.\ngreetd/tuigreet was built, functionally complete, and\nabandoned before integration. Fewer moving parts,\nsmaller attack surface, at the cost of the desktop\nnot starting automatically."];
}
