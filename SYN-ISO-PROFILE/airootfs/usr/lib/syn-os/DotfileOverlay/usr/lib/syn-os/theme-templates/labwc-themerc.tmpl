!! SYN_THEME_NAME
!! Font: Terminus

border.width:                   2
border.color:                   SYN_BG_ALT

padding.width:                  1
padding.height:                 1

window.handle.width:            0
window.client.padding.width:    0
window.client.padding.height:   0

window.active.cornerRadius:     0
window.inactive.cornerRadius:   0

window.active.shadow.size:      0
window.inactive.shadow.size:    0

window.active.label.text.font:  Terminus 10
window.label.text.justify:      left

menu.title.text.font:           Terminus 10
menu.title.text.justify:        left

menu.items.font:                Terminus 10

# Default max is 200px — clips anything past ~28 characters at this font.
# Several real entries run well past that (SYN-CRYPTER, SYN-NETSERVER,
# "Record - select area / Stop", the longest Capture entries) — 340 was
# tuned against the old menu's longest label and got outgrown the moment
# Capture was added. 460 covers every current real label with margin.
menu.width.min:                 200
menu.width.max:                 460

menu.border.width:              5
menu.overlap.x:                 -10
menu.overlap.y:                 -10

menu.title.bg:                  flat solid
menu.title.bg.color:            SYN_BG_ALT
menu.title.text.color:          SYN_ACCENT

menu.items.bg:                  flat solid
menu.items.bg.color:            SYN_BG
menu.items.text.color:          SYN_ACCENT

menu.items.active.bg:           flat solid
menu.items.active.bg.color:     SYN_ACCENT
# Hardcoded, not SYN_BG: every theme's SYN_ACCENT is saturated/dark enough
# for white text to read, including light themes where SYN_BG is near-white
# and would otherwise render invisible white-on-white hover text.
menu.items.active.text.color:   #ffffff

menu.items.disabled.text.color: SYN_BORDER

window.active.padding.width:    10
window.active.title.bg:         flat solid
window.active.title.bg.color:   SYN_BG_ALT

window.active.label.bg:         flat solid
window.active.label.bg.color:   SYN_BG_ALT
window.active.label.text.color: SYN_ACCENT

window.active.handle.bg:        flat solid
window.active.handle.bg.color:  SYN_BG

window.active.grip.bg:          flat solid
window.active.grip.bg.color:    SYN_BG_ALT

window.active.client.color:     SYN_BG_ALT
window.inactive.client.color:   SYN_BG_ALT

window.inactive.title.bg:       flat solid
window.inactive.title.bg.color: SYN_BG_ALT

window.inactive.label.bg:       parentrelative
window.inactive.label.text.color: SYN_ACCENT_DIM

window.inactive.handle.bg:      flat solid
window.inactive.handle.bg.color: SYN_BG_ALT

window.inactive.grip.bg:        flat solid
window.inactive.grip.bg.color:  SYN_BG_ALT

window.active.indicator.tiled.color: SYN_ACCENT

window.active.button.unpressed.bg:           flat solid
window.active.button.unpressed.bg.color:     SYN_BG_ALT
window.active.button.unpressed.image.color:  SYN_ACCENT

window.active.button.pressed.bg:             flat solid
window.active.button.pressed.bg.color:       SYN_BG_ALT
window.active.button.pressed.image.color:    SYN_ACCENT

window.active.button.hover.bg:               flat solid
window.active.button.hover.bg.color:         SYN_PANEL_HOVER
window.active.button.hover.image.color:      SYN_ACCENT

window.active.button.disabled.bg:            parentrelative
window.active.button.disabled.image.color:   SYN_ACCENT

window.inactive.button.unpressed.bg:         parentrelative
window.inactive.button.unpressed.image.color: SYN_ACCENT_DIM

window.inactive.button.hover.bg:             flat solid
window.inactive.button.hover.bg.color:       SYN_ACCENT
window.inactive.button.pressed.bg:           flat solid
window.inactive.button.pressed.bg.color:     SYN_ACCENT

window.inactive.button.disabled.bg:          parentrelative
window.inactive.button.disabled.image.color: SYN_ACCENT

osd.border.width:       2
osd.border.color:       SYN_BG_ALT

osd.bg:                 flat solid
osd.bg.color:            SYN_BG
osd.label.text.color:   SYN_ACCENT
osd.label.text.font:    Terminus 10

osd.hilight.bg:         flat solid
osd.hilight.bg.color:   SYN_ACCENT_DIM

osd.unhilight.bg:       flat solid
osd.unhilight.bg.color: SYN_BG_ALT
