!! SYN_THEME_NAME
!! Font: Terminus
!! Slab family: thick borders, square corners, heavy flat-solid fills —
!! the opposite of Flatline. Same key pruning as the other overrides:
!! labwc-theme(5) doesn't implement cornerRadius, window.active.label.bg,
!! .client.color, .handle.bg, .grip.bg, or .indicator.tiled.color.

border.width:                   6
padding.width:                  3
padding.height:                 3

window.handle.width:            8
window.client.padding.width:    0
window.client.padding.height:   0

window.active.shadow.size:      0
window.inactive.shadow.size:    0

window.active.label.text.font:  Terminus Bold 11
window.label.text.justify:      center

menu.title.text.font:           Terminus Bold 10
menu.title.text.justify:        center
menu.items.font:                Terminus 10

menu.width.min:                 220
menu.width.max:                 460
menu.border.width:              6
menu.overlap.x:                 0
menu.overlap.y:                 0

menu.title.bg:                  flat solid
menu.title.bg.color:            SYN_ACCENT
menu.title.text.color:          SYN_BG

menu.items.bg:                  flat solid
menu.items.bg.color:            SYN_PANEL
menu.items.text.color:          SYN_TEXT

menu.items.active.bg:           flat solid
menu.items.active.bg.color:     SYN_ACCENT
menu.items.active.text.color:   SYN_BG

menu.items.disabled.text.color: SYN_BORDER
menu.separator.color:           SYN_BORDER

window.active.border.color:        SYN_ACCENT
window.inactive.border.color:      SYN_BORDER

window.active.padding.width:       12
window.active.title.bg:            flat solid
window.active.title.bg.color:      SYN_ACCENT
window.active.label.text.color:    SYN_BG

window.active.handle.bg:           flat solid
window.active.handle.bg.color:     SYN_PANEL

window.inactive.title.bg:          flat solid
window.inactive.title.bg.color:    SYN_PANEL
window.inactive.label.text.color:  SYN_BORDER

window.inactive.handle.bg:         flat solid
window.inactive.handle.bg.color:   SYN_PANEL

window.active.button.unpressed.bg:            flat solid
window.active.button.unpressed.bg.color:      SYN_ACCENT
window.active.button.unpressed.image.color:   SYN_BG

window.active.button.hover.bg:                flat solid
window.active.button.hover.bg.color:          SYN_BG
window.active.button.hover.image.color:       SYN_ACCENT

window.inactive.button.unpressed.bg:          flat solid
window.inactive.button.unpressed.bg.color:    SYN_PANEL
window.inactive.button.unpressed.image.color: SYN_BORDER

osd.border.width:       6
osd.border.color:       SYN_ACCENT
osd.bg:                 flat solid
osd.bg.color:            SYN_PANEL
osd.label.text.color:   SYN_TEXT
osd.label.text.font:    Terminus Bold 10
osd.hilight.bg:         flat solid
osd.hilight.bg.color:   SYN_ACCENT
osd.unhilight.bg:       flat solid
osd.unhilight.bg.color: SYN_PANEL
