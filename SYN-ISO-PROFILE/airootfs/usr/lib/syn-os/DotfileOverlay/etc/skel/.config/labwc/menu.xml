<?xml version="1.0" encoding="UTF-8"?>
<openbox_menu xmlns="http://openbox.org/3.4/menu">

  <menu id="root-menu" label="SYN-OS">

    <!-- Applications: general-purpose software. "All Applications" is a
         live pipe-menu (xdg_menu, regenerated from whatever's actually
         installed) — not a hand-sorted list, and not something to merge
         with the hand-placed items below it. -->
    <separator label=" APPLICATIONS " />

    <item label="Terminal">
      <action name="Execute">
        <command>foot</command>
      </action>
    </item>

    <item label="File browser">
      <action name="Execute">
        <command>syn-filemanager</command>
      </action>
    </item>

    <menu id="dynamic_apps"
          label="All Applications"
          execute="xdg_menu --format openbox3-pipe --root-menu /etc/xdg/menus/arch-applications.menu" />

    <!-- BLACKARCH-MENU-START/END: inserted/removed here by
         syn-blackarch-toggle.zsh's Enable/Disable — not present until
         toggled on, so nothing advertises BlackArch to a system that
         doesn't have it. See Preferences > BlackArch. -->
    <!-- BLACKARCH-MENU-END -->

    <!-- Capture: "do something with what's on screen right now" from the
         user's own seat, same shelf as Applications. screen-recorder.zsh
         toggles: click Record once to start (backgrounded, PID tracked in
         $XDG_RUNTIME_DIR), the same entry again to stop. Display & Screens
         is actual output configuration, not a launched action — that
         lives in Preferences below, not here. -->
    <menu id="capture-menu" label="Capture">
      <item label="Screenshot - full screen">
        <action name="Execute">
          <command>/usr/lib/syn-os/screenshot.zsh full</command>
        </action>
      </item>

      <item label="Screenshot - select area">
        <action name="Execute">
          <command>/usr/lib/syn-os/screenshot.zsh region</command>
        </action>
      </item>

      <item label="Record - full screen">
        <action name="Execute">
          <command>/usr/lib/syn-os/screen-recorder.zsh full</command>
        </action>
      </item>

      <item label="Record - select area / Stop">
        <action name="Execute">
          <command>/usr/lib/syn-os/screen-recorder.zsh region</command>
        </action>
      </item>
    </menu>

    <!-- SYN-OS Tools: every purpose-built tool this project ships lives
         here, and only here — one place, one rule, instead of the old
         split where Wi-Fi/Volume/Monitor sat under System while
         Share/Crypter/Graphmap/Docs sat in their own menu for no
         principled reason. If it's a tool SYN-OS built, it's in this
         list. If it's a system-maintenance action (kill a process, edit
         a config file, restart the bar), it's in System instead — see
         the separator there. Each opens in a terminal since they're
         interactive TUIs, not GUI apps; every entry ends its script with
         `; exec zsh` so an early failure (missing dependency, permission
         error) leaves the terminal open with the error visible instead
         of the window just vanishing. -->
    <separator label=" SYN-OS TOOLS " />

    <menu id="synos-tools" label="SYN-OS Tools">
      <item label="Wi-Fi Picker">
        <action name="Execute">
          <command>foot -e /usr/lib/syn-os/syn-wifi</command>
        </action>
      </item>

      <item label="Volume Mixer">
        <action name="Execute">
          <command>foot -e /usr/lib/syn-os/syn-audio</command>
        </action>
      </item>

      <!-- Three separate entries (not one syn-sysmon launcher the user
           Tabs from) so each jumps straight to the stat you actually
           want, same deep-link the matching waybar icon's on-click uses. -->
      <item label="System Monitor - CPU">
        <action name="Execute">
          <command>foot -e /usr/lib/syn-os/syn-sysmon --view=cpu</command>
        </action>
      </item>

      <item label="System Monitor - RAM">
        <action name="Execute">
          <command>foot -e /usr/lib/syn-os/syn-sysmon --view=mem</command>
        </action>
      </item>

      <item label="System Monitor - Sensors">
        <action name="Execute">
          <command>foot -e /usr/lib/syn-os/syn-sysmon --view=sensors</command>
        </action>
      </item>

      <!-- Opens straight to the unit picker, not any single stat — the
           waybar cpu/memory/temperature icons already deep-link to their
           own syn-sysmon view, so this is deliberately the one entry
           point not duplicated on the bar itself. -->
      <item label="System Logs">
        <action name="Execute">
          <command>foot -e /usr/lib/syn-os/syn-sysmon --view=logs</command>
        </action>
      </item>

      <menu id="syn-share-menu"
            label="SYN-SHARE (file transfer hub)"
            execute="zsh /usr/lib/syn-os/syn-pipe-share.zsh" />

      <!-- syn-crypter is its own interactive ncurses TUI (menus + a real
           directory-browsing file picker + masked password entry, all
           colored from the live SYN-OS theme) when run with no
           arguments — unlike SYN-SHARE above, it needs no rofi-based
           prompt script in front of it; foot -e runs it directly. Covers
           AES-256, Blowfish, RSA, and Redshirt (the Uplink-style XOR
           joke "encryption") all from its own algorithm menu, so there's
           no separate SYN-REDSHIRT entry anymore either. -->
      <item label="SYN-CRYPTER (AES/Blowfish/RSA/Redshirt file encryption)">
        <action name="Execute">
          <command>foot -e /usr/lib/syn-os/syn-crypter</command>
        </action>
      </item>

      <!-- SYN-GRAPHMAP always prompts via rofi for the target directory
           and output format (leaving both args empty triggers those
           prompts); Quick/Full only differ in the max-depth passed
           directly. Custom asks for a number via its own small prompt
           script first. Output lands in ~/Pictures/SYN-GRAPHMAP/, same
           convention as screenshots. -->
      <menu id="graphmap-menu" label="SYN-GRAPHMAP (graph a directory tree)">
        <item label="Quick (shallow scan)">
          <action name="Execute">
            <command>/usr/lib/syn-os/syn-graphmap-quick.zsh</command>
          </action>
        </item>

        <item label="Full (deep scan)">
          <action name="Execute">
            <command>/usr/lib/syn-os/syn-graphmap-full.zsh</command>
          </action>
        </item>

        <item label="Custom (enter a depth)">
          <action name="Execute">
            <command>/usr/lib/syn-os/syn-graphmap-custom.zsh</command>
          </action>
        </item>
      </menu>

      <!-- The ISO build itself stays a full, normal, decorated terminal —
           it runs for minutes with real scrolling output, unlike every
           other tool here's one-line result. syn-build-launcher.zsh
           handles its own doas framing internally. -->
      <item label="SYN-OS ISO Builder">
        <action name="Execute">
          <command>foot -e zsh -c 'zsh /usr/lib/syn-os/syn-build-launcher.zsh; exec zsh'</command>
        </action>
      </item>

      <!-- Reference material you open, not a tool you run — but it's the
           same shape as everything above it (a thing SYN-OS built that
           needs a menu entry to be findable at all), so it lives here
           rather than under Preferences, which is settings you tune. -->
      <menu id="docs-pipe"
            label="Docs"
            execute="/usr/lib/syn-os/syn-pipe-docs.zsh" />
    </menu>

    <!-- Audio / Display / Themes / Bar toggle: settings you tune, tucked
         one level deep instead of sitting bare at root. Audio/Display/
         Themes are each a real dynamic pipe-menu (queries pactl/wlr-randr/
         theme dir live). -->
    <separator label=" SETTINGS " />

    <menu id="preferences-menu" label="Preferences">
      <!-- Desktop settings: live, cosmetic/hardware controls you tune to
           taste. Each of Audio/Display/Themes is a real dynamic pipe-menu
           (queries pactl/wlr-randr/theme dir live), not a static list. -->
      <separator label=" DESKTOP " />

      <menu id="audio-pipe"
            label="Audio Settings"
            execute="/usr/lib/syn-os/syn-pipe-audio.zsh" />

      <menu id="displays-pipe"
            label="Display &amp; Screens"
            execute="/usr/lib/syn-os/syn-pipe-display.zsh" />

      <menu id="themes-pipe"
            label="Themes"
            execute="/usr/lib/syn-os/syn-pipe-theme.zsh" />

      <item label="Toggle Bar Position">
        <action name="Execute" command="/usr/lib/syn-os/syn-bar-toggle-position.zsh" />
      </item>

      <!-- System toggles: enabling/disabling actual software, distinct
           from the cosmetic settings above. Both are live toggles on any
           already-installed system, no reinstall needed. No foot wrapper —
           the rofi pickers are their own popups, and each script opens its
           own syn_popup::run window for the actual doas action once a
           choice is made. -->
      <separator label=" SOFTWARE " />

      <item label="BlackArch">
        <action name="Execute">
          <command>/usr/lib/syn-os/syn-blackarch-toggle.zsh</command>
        </action>
      </item>

      <!-- Lists every real enabled/disabled systemd service on the box
           (queried live), not a fixed shortlist — see
           syn-services-toggle.zsh's own header for why. -->
      <item label="Services (enable/disable any systemd unit)">
        <action name="Execute">
          <command>/usr/lib/syn-os/syn-services-toggle.zsh</command>
        </action>
      </item>
    </menu>

    <!-- System: maintenance actions only — locking the screen, killing a
         stuck process, editing a config file by hand, restarting the bar
         or the compositor. Every SYN-OS tool used to live scattered
         between here and the old Tools menu with no consistent rule for
         which one a given tool landed in; they've all moved to SYN-OS
         Tools above, so everything left in this menu is genuinely about
         maintaining the running session, not launching a tool. -->
    <separator label=" SYSTEM " />

    <menu id="system-menu" label="System">
      <item label="Lock Screen">
        <action name="Execute">
          <command>swaylock -f -c 1a0000</command>
        </action>
      </item>

      <!-- Waybar/LabWC have their own entries below (Waybar & LabWC menu
           for launch/reload, Kill Process for the kill side of both) —
           this is for the other common programs, kept to a short, known
           list on purpose rather than a full process browser. -->
      <menu id="kill-process" label="Kill Process">
        <item label="Close Focused Window">
          <action name="Close" />
        </item>

        <item label="Kill All Terminals (foot)">
          <action name="Execute">
            <command>pkill foot</command>
          </action>
        </item>

        <item label="Kill Web Browser (Falkon)">
          <action name="Execute">
            <command>pkill falkon</command>
          </action>
        </item>

        <item label="Kill File Browser (syn-filemanager)">
          <action name="Execute">
            <command>pkill syn-filemanager</command>
          </action>
        </item>

        <!-- Genuinely a kill action (of labwc itself, the escape hatch
             back to a bare tty) — belongs here with the other kills, not
             paired with Waybar & LabWC's launch/reload actions below. -->
        <item label="Return to Tty1 (Kill LabWC)">
          <action name="Execute">
            <command>pkill labwc</command>
          </action>
        </item>
      </menu>

      <menu id="edit-configs" label="Edit Configuration Files">

        <!-- Waybar Configurations -->
        <menu id="waybar-config" label="Waybar Configurations">
          <item label="Waybar Config">
            <action name="Execute">
              <command>featherpad ~/.config/waybar/config.jsonc</command>
            </action>
          </item>
          <!-- syn-theme-apply (see Themes above) overwrites this file
               wholesale on every theme switch. Fine for a one-off tweak,
               won't survive switching themes. -->
          <item label="Waybar Style (overwritten by Themes switch)">
            <action name="Execute">
              <command>featherpad ~/.config/waybar/style.css</command>
            </action>
          </item>
        </menu>

        <!-- LabWC Configurations -->
        <menu id="labwc-config" label="LabWC Configurations">
          <!-- This whole menu is this one plain text file. Add your own
               launchers the same way every item above does: an <item> with
               a <command>. Nothing here is special-cased or hidden from you. -->
          <item label="Labwc Menu">
            <action name="Execute">
              <command>featherpad ~/.config/labwc/menu.xml</command>
            </action>
          </item>

          <item label="Labwc RC">
            <action name="Execute">
              <command>featherpad ~/.config/labwc/rc.xml</command>
            </action>
          </item>

          <item label="Labwc Autostart">
            <action name="Execute">
              <command>featherpad ~/.config/labwc/autostart</command>
            </action>
          </item>
        </menu>

      </menu>

      <!-- Launch/reload only — SYN-OS never auto-starts a GUI session on
           its own, waybar/labwc restarting is a routine part of driving
           the desktop rather than a rare recovery action, so both live
           here as one clean step each. The kill side of each (labwc's
           "Return to Tty1", waybar's half of the restart below) lives in
           Kill Process instead — see the comment there. -->
      <menu id="waybar-labwc" label="Waybar &amp; LabWC">
        <item label="Reload LabWC Configuration">
          <action name="Reconfigure" />
        </item>

        <!-- One action, not separate Launch/Kill entries — "kill" alone
             leaves no bar, "launch" alone assumes it's already dead;
             neither is useful on its own the way Kill Process's other
             entries are. -->
        <item label="Restart Waybar">
          <action name="Execute">
            <command>pkill waybar; waybar</command>
          </action>
        </item>
      </menu>
    </menu>

    <!-- Power -->
    <separator label=" POWER " />

    <menu id="power-menu" label="Power Options">
      <item label="Reboot">
        <action name="Execute">
          <command>systemctl reboot</command>
        </action>
      </item>

      <item label="Power Off">
        <action name="Execute">
          <command>systemctl poweroff</command>
        </action>
      </item>
    </menu>

  </menu>

</openbox_menu>
