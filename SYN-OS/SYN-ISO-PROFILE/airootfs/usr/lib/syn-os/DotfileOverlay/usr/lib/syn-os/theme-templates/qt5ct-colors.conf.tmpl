[ColorScheme]
# Role order is Qt5's QPalette::ColorRole enum (verified against qpalette.h
# and cross-checked against qt5ct's own shipped /usr/share/qt5ct/colors/darker.conf):
# WindowText, Button, Light, Midlight, Dark, Mid, Text, BrightText, ButtonText,
# Base, Window, Shadow, Highlight, HighlightedText, Link, LinkVisited,
# AlternateBase, NoRole, ToolTipBase, ToolTipText, PlaceholderText.
# A prior version of this file had background/foreground roles swapped
# (WindowText=bg, Window/Base=text), which rendered every Qt app white-on-white.
active_colors=SYN_TEXT_FF, SYN_PANEL_FF, SYN_PANEL_HOVER_FF, SYN_PANEL_FF, SYN_BG_ALT_FF, SYN_BORDER_FF, SYN_TEXT_FF, SYN_TEXT_FF, SYN_TEXT_FF, SYN_BG_ALT_FF, SYN_BG_FF, SYN_BG_ALT_FF, SYN_ACCENT_FF, SYN_TEXT_FF, SYN_ACCENT_FF, SYN_ACCENT_DIM_FF, SYN_BG_ALT_FF, SYN_TEXT_FF, SYN_BG_ALT_FF, SYN_TEXT_FF, SYN_ACCENT_80
disabled_colors=SYN_BORDER_FF, SYN_PANEL_FF, SYN_PANEL_HOVER_FF, SYN_PANEL_FF, SYN_BG_ALT_FF, SYN_BORDER_FF, SYN_BORDER_FF, SYN_BORDER_FF, SYN_BORDER_FF, SYN_BG_ALT_FF, SYN_BG_FF, SYN_BG_ALT_FF, SYN_ACCENT_DIM_FF, SYN_BORDER_FF, SYN_ACCENT_DIM_FF, SYN_ACCENT_DIM_FF, SYN_BG_ALT_FF, SYN_BORDER_FF, SYN_BG_ALT_FF, SYN_BORDER_FF, SYN_ACCENT_80
inactive_colors=SYN_TEXT_FF, SYN_PANEL_FF, SYN_PANEL_HOVER_FF, SYN_PANEL_FF, SYN_BG_ALT_FF, SYN_BORDER_FF, SYN_TEXT_FF, SYN_TEXT_FF, SYN_TEXT_FF, SYN_BG_ALT_FF, SYN_BG_FF, SYN_BG_ALT_FF, SYN_ACCENT_FF, SYN_TEXT_FF, SYN_ACCENT_FF, SYN_ACCENT_DIM_FF, SYN_BG_ALT_FF, SYN_TEXT_FF, SYN_BG_ALT_FF, SYN_TEXT_FF, SYN_ACCENT_80
