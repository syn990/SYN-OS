!! SYN_THEME_NAME
!! Font: Terminus
!! Colors from the third-party "Retro 1 (Terminal)" Matrix/Green-DOS
!! openbox themerc (by Anna Schroder). Uses ONLY keys labwc actually
!! implements per labwc-theme(5) — no window.active.label.bg, .client.color,
!! .handle.bg, .grip.bg, .indicator.tiled.color, cornerRadius, or
!! per-button-state .bg: none of those exist in labwc and are silently
!! ignored if set.

border.width:                   1
window.titlebar.padding.width:  3
window.titlebar.padding.height: 3

window.active.shadow.size:      0
window.inactive.shadow.size:    0

window.label.text.justify:      Left

menu.title.text.justify:        Center
menu.border.width:              1
menu.overlap.x:                 4
menu.overlap.y:                 -2

window.active.border.color:     SYN_ACCENT
window.inactive.border.color:   SYN_ACCENT_DIM

window.active.title.bg:            Solid
window.active.title.bg.color:      SYN_BG
window.active.label.text.color:    SYN_ACCENT

window.inactive.title.bg:          Solid
window.inactive.title.bg.color:    SYN_BG
window.inactive.label.text.color:  SYN_ACCENT_DIM

window.button.hover.bg.color:                 SYN_PANEL_HOVER
window.active.button.unpressed.image.color:   SYN_ACCENT
window.inactive.button.unpressed.image.color: SYN_ACCENT_DIM

menu.items.bg.color:            SYN_BG
menu.items.text.color:          SYN_TEXT

menu.items.active.bg.color:     SYN_PANEL
menu.items.active.text.color:   SYN_ACCENT

menu.separator.color:           SYN_ACCENT

menu.title.bg.color:            SYN_BG
menu.title.text.color:          SYN_ACCENT

osd.border.width:       1
osd.border.color:       SYN_BORDER
osd.bg.color:            SYN_BG
osd.label.text.color:   SYN_ACCENT
