. /usr/lib/syn-os/syn-theme-lib.zsh

# Restores outputs persisted as "always OFF at boot" via the Display &
# Screens menu (~/.config/syn-os/disabled-outputs, one real wlr-randr
# output name per line). A persisted output only actually turns off if
# another one is confirmed on first — never leaving a black screen.
apply_persisted_display_state() {
  DISABLED_OUTPUTS_FILE="$HOME/.config/syn-os/disabled-outputs"
  if [ -f "$DISABLED_OUTPUTS_FILE" ] && command -v wlr-randr >/dev/null 2>&1; then
    wlr_state="$(wlr-randr 2>/dev/null)"
    # Anchored on each output's own block boundary (a line starting with
    # its name), not proximity-based grep, since the gap to Enabled:
    # varies by output.
    per_output_state="$(echo "$wlr_state" | awk '
      /^[A-Za-z]/ { name = $1 }
      /Enabled:/ { print name "|" $2 }
    ')"
    total_enabled="$(echo "$per_output_state" | grep -c "|yes" || true)"

    while IFS= read -r out_name; do
      [ -z "$out_name" ] && continue
      out_line="$(echo "$per_output_state" | grep "^${out_name}|" || true)"
      [ -z "$out_line" ] && continue  # not a currently-detected output, skip
      out_is_enabled="no"
      case "$out_line" in *"|yes") out_is_enabled="yes" ;; esac

      if [ "$out_is_enabled" = "yes" ] && [ "${total_enabled:-0}" -gt 1 ]; then
        wlr-randr --output "$out_name" --off 2>/dev/null
      elif [ "${total_enabled:-0}" -eq 0 ]; then
        wlr-randr --output "$out_name" --on 2>/dev/null
      fi
    done < "$DISABLED_OUTPUTS_FILE"
  fi
}

# First login (no current-theme yet): stamps the default theme into every
# app's own config format via syn-theme-apply. Later logins: current-theme
# already reflects an applied theme, so just relaunch its wallpaper —
# re-running syn-theme-apply here isn't needed and would be redundant work
# on every login.
bootstrap_or_relaunch_theme() {
  if [ -f "$HOME/.config/syn-os/current-theme" ]; then
    ( syn_theme_load
      [ -n "$SYN_WALLPAPER" ] && [ -f "$SYN_WALLPAPER" ] && swaybg -i "$SYN_WALLPAPER" & )
  else
    syn-theme-apply SYN-OS-RED
  fi
}

apply_persisted_display_state
bootstrap_or_relaunch_theme
waybar
