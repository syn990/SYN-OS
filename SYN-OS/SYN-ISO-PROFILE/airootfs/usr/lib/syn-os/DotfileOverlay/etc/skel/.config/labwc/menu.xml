<?xml version="1.0" encoding="UTF-8"?>
<openbox_menu xmlns="http://openbox.org/3.4/menu">

  <menu id="root-menu" label="SYN-OS">

    <!-- Applications -->
    <separator label=" APPLICATIONS " />

    <item label="Terminal">
      <action name="Execute">
        <command>foot</command>
      </action>
    </item>

    <!-- File Browser -->
    <item label="File browser">
      <action name="Execute">
        <command>~/.config/labwc/spf-menu.zsh</command>
      </action>
    </item>

    <menu id="dynamic_apps"
          label="All Applications"
          execute="xdg_menu --format openbox3-pipe --root-menu /etc/xdg/menus/arch-applications.menu" />

    <!-- SYN-OS Tools: the custom scripts in /usr/lib/syn-os/ have no other
         GUI entry point — without this menu the only way to find them is
         already knowing the filename. Each opens in a terminal since
         they're all interactive TUIs, not GUI apps. -->
    <separator label=" SYN-OS TOOLS " />

    <menu id="synos-tools" label="SYN-OS Tools">
      <item label="SYN-SHARE (file transfer hub)">
        <action name="Execute">
          <command>foot -e zsh /usr/lib/syn-os/syn-share.zsh</command>
        </action>
      </item>

      <item label="SYN-NETCLIENT (probe/pull from a SYN-OS host)">
        <action name="Execute">
          <command>foot -e zsh /usr/lib/syn-os/syn-netclient.zsh</command>
        </action>
      </item>

      <item label="SYN-NETSERVER (manage file-transfer services)">
        <action name="Execute">
          <command>foot -e doas zsh /usr/lib/syn-os/syn-netserver.zsh</command>
        </action>
      </item>

      <!-- syn-crypter.zsh and syn-redshirt.zsh take flags and a file path
           on the command line (no interactive prompts of their own) — there's
           no sensible default file to run them against, so drop into a shell
           with the usage banner already printed instead of launching them
           directly, which would just flash-and-exit with an arg error. -->
      <item label="SYN-CRYPTER (AES/Blowfish/RSA file encryption)">
        <action name="Execute">
          <command>foot -e zsh -c 'zsh /usr/lib/syn-os/syn-crypter.zsh; exec zsh'</command>
        </action>
      </item>

      <item label="SYN-REDSHIRT (Uplink-style XOR obfuscation)">
        <action name="Execute">
          <command>foot -e zsh -c 'zsh /usr/lib/syn-os/syn-redshirt.zsh; exec zsh'</command>
        </action>
      </item>
    </menu>

    <!-- System Control -->
    <separator label=" SYSTEM CONTROL " />

    <item label="Lock Screen (Super+L)">
      <action name="Execute">
        <command>swaylock -f -c 1a0000</command>
      </action>
    </item>

    <item label="Screenshot - select area (Super+P)">
      <action name="Execute">
        <command>sh -lc 'mkdir -p ~/Pictures/Screenshots; grim -g "$(slurp)" ~/Pictures/Screenshots/$(date +%F_%H-%M-%S).png'</command>
      </action>
    </item>

    <item label="Volume Mixer">
      <action name="Execute">
        <command>pavucontrol-qt</command>
      </action>
    </item>

    <!-- Waybar/LabWC have their own kill entries above (Waybar & LabWC
         submenu) — this is for the other common programs, kept to a short,
         known list on purpose rather than a full process browser. -->
    <menu id="kill-process" label="Kill Process">
      <item label="Close Focused Window (Super+Q)">
        <action name="Close" />
      </item>

      <item label="Kill All Terminals (foot)">
        <action name="Execute">
          <command>pkill foot</command>
        </action>
      </item>

      <item label="Kill Web Browser (Falkon)">
        <action name="Execute">
          <command>pkill falkon</command>
        </action>
      </item>

      <item label="Kill File Browser (Superfile)">
        <action name="Execute">
          <command>pkill spf</command>
        </action>
      </item>
    </menu>

    <menu id="audio-pipe"
          label="Audio Settings (Dynamic)"
          execute="~/.config/labwc/labwc-audio-menu.zsh" />

    <menu id="displays-pipe"
          label="Display &amp; Screens (Dynamic)"
          execute="~/.config/labwc/labwc-wlr-menu.zsh" />

    <!-- Themes: live switch, no hand-editing needed. See "Edit Configuration
         Files" below only if you want to go past what a theme covers. -->
    <menu id="themes-pipe"
          label="Themes"
          execute="~/.config/labwc/syn-theme-menu.zsh" />

    <!-- Configuration (Interface and System) -->
    <separator label=" CONFIGURATION " />

    <menu id="edit-configs" label="Edit Configuration Files">

      <!-- Waybar Configurations -->
      <menu id="waybar-config" label="Waybar Configurations">
        <item label="Waybar Config">
          <action name="Execute">
            <command>featherpad ~/.config/waybar/config.jsonc</command>
          </action>
        </item>
        <!-- syn-theme-apply (see Themes above) overwrites this file
             wholesale on every theme switch. Fine for a one-off tweak,
             won't survive switching themes. -->
        <item label="Waybar Style (overwritten by Themes switch)">
          <action name="Execute">
            <command>featherpad ~/.config/waybar/style.css</command>
          </action>
        </item>
      </menu>

      <!-- LabWC Configurations -->
      <menu id="labwc-config" label="LabWC Configurations">
        <!-- This whole menu is this one plain text file. Add your own
             launchers the same way every item above does: an <item> with
             a <command>. Nothing here is special-cased or hidden from you. -->
        <item label="Labwc Menu">
          <action name="Execute">
            <command>featherpad ~/.config/labwc/menu.xml</command>
          </action>
        </item>

        <item label="Labwc RC">
          <action name="Execute">
            <command>featherpad ~/.config/labwc/rc.xml</command>
          </action>
        </item>

        <item label="Labwc Autostart">
          <action name="Execute">
            <command>featherpad ~/.config/labwc/autostart</command>
          </action>
        </item>
      </menu>

    </menu>

    <!-- Interface -->
    <separator label=" INTERFACE " />

    <menu id="waybar-labwc" label="Waybar &amp; LabWC">
      <item label="Reload LabWC Configuration">
        <action name="Reconfigure" />
      </item>

      <item label="Return to Tty1 (Kill LabWC)">
        <action name="Execute">
          <command>pkill labwc</command>
        </action>
      </item>

      <item label="Launch Waybar">
        <action name="Execute">
          <command>waybar</command>
        </action>
      </item>

      <item label="Kill Waybar">
        <action name="Execute">
          <command>pkill waybar</command>
        </action>
      </item>
    </menu>

    <!-- Power -->
    <separator label=" POWER " />

    <menu id="power-menu" label="Power Options">
      <item label="Reboot">
        <action name="Execute">
          <command>systemctl reboot</command>
        </action>
      </item>

      <item label="Power Off">
        <action name="Execute">
          <command>systemctl poweroff</command>
        </action>
      </item>
    </menu>

  </menu>

</openbox_menu>
