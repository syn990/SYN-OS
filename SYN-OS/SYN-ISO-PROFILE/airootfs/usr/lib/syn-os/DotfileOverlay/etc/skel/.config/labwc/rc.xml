<?xml version="1.0" encoding="UTF-8"?>
<labwc_config>

  <theme>
    <name>SYN-OS-RED</name>
    <titleLayout>NLIMC</titleLayout>

    <font place="ActiveWindow">
      <name>Terminus</name>
      <size>10</size>
      <weight>Bold</weight>
    </font>
    <font place="InactiveWindow">
      <name>Terminus</name>
      <size>10</size>
    </font>
    <font place="MenuHeader">
      <name>Terminus</name>
      <size>10</size>
      <weight>Bold</weight>
    </font>
    <font place="MenuItem">
      <name>Terminus</name>
      <size>10</size>
    </font>
    <font place="OnScreenDisplay">
      <name>Terminus</name>
      <size>10</size>
    </font>
  </theme>

  <!-- foot windows launched with app-id syn-os-popup (syn-popup-lib.zsh,
       used by every menu.xml tool that runs a command and shows the
       result — SYN-SHARE, BlackArch/services toggles, the ISO builder,
       crypter/redshirt/graphmap) render as a small, undecorated,
       centered popup instead of a normal terminal window — matches the
       rofi popups' feel, not something meant to be resized/moved/left
       open indefinitely. -->
  <windowRules>
    <windowRule identifier="syn-os-popup" serverDecoration="no">
      <action name="ResizeTo" width="640" height="360" />
      <action name="AutoPlace" policy="center" />
    </windowRule>
  </windowRules>

  <desktops number="4">
    <names>
      <name>🃁 [Terminal]</name>
      <name>ℐ [Web]</name>
      <name>ℕ [Media]</name>
      <name>⌘ [External]</name>
    </names>
  </desktops>
  
<mouse>
  <mousebind button="A-Left" action="Move"/>
  <mousebind button="A-Right" action="Resize"/>
  <mousebind button="A-Middle" action="Lower"/> 
</mouse>

  <keyboard>

    <keybind key="W-space">
      <action name="ShowMenu" menu="root-menu"/>
    </keybind>

    <keybind key="W-Escape">
      <action name="Reconfigure"/>
    </keybind>

    <keybind key="W-l">
      <action name="Execute" command="swaylock -f -c 1a0000"/>
    </keybind>

    <keybind key="W-S-e">
      <action name="Exit"/>
    </keybind>

    <keybind key="W-Return">
      <action name="Execute" command="foot"/>
    </keybind>

    <keybind key="W-a">
      <action name="Execute" command="fuzzel"/>
    </keybind>

    <keybind key="W-q">
      <action name="Close"/>
    </keybind>

    <keybind key="A-Tab">
      <action name="NextWindow"/>
    </keybind>
    <keybind key="A-S-Tab">
      <action name="PreviousWindow"/>
    </keybind>
    <keybind key="W-Tab">
      <action name="ToggleMaximize"/>
    </keybind>

    <keybind key="W-S-Left"><action name="MoveToEdge" direction="left"/></keybind>
    <keybind key="W-S-Right"><action name="MoveToEdge" direction="right"/></keybind>
    <keybind key="W-S-Up"><action name="MoveToEdge" direction="up"/></keybind>
    <keybind key="W-S-Down"><action name="MoveToEdge" direction="down"/></keybind>

    <keybind key="C-A-Left"><action name="GoToDesktop" to="left" wrap="no"/></keybind>
    <keybind key="C-A-Right"><action name="GoToDesktop" to="right" wrap="no"/></keybind>
    <keybind key="S-A-Left"><action name="SendToDesktop" to="left" wrap="no"/></keybind>
    <keybind key="S-A-Right"><action name="SendToDesktop" to="right" wrap="no"/></keybind>

    <keybind key="W-1"><action name="GoToDesktop" to="1"/></keybind>
    <keybind key="W-2"><action name="GoToDesktop" to="2"/></keybind>
    <keybind key="W-3"><action name="GoToDesktop" to="3"/></keybind>
    <keybind key="W-4"><action name="GoToDesktop" to="4"/></keybind>

    <keybind key="W-p">
      <action name="Execute" command="/usr/lib/syn-os/screenshot.zsh region"/>
    </keybind>

    <keybind key="W-S-p">
      <action name="Execute" command="/usr/lib/syn-os/screen-recorder.zsh full"/>
    </keybind>

  </keyboard>

</labwc_config>
