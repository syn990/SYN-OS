digraph wifi_connect_flow {
  rankdir=TB;
  bgcolor="#000000";
  fontname="monospace";
  node [shape=box, style="rounded,filled", fillcolor="#4d0000", color="#e00000", fontcolor="white", fontname="monospace", fontsize=10];
  edge [color="#AAAAAA", fontcolor="white", fontname="monospace", fontsize=9];

  label="syn-bar-wifi.zsh: from a bar click to a connected network";
  labelloc="t"; fontsize=14; fontcolor="#ff6666";

  click [label="click waybar's\nnetwork module", shape=oval, fillcolor="#1a0000"];

  device [label="iwctl device list\n(ANSI-stripped, match\ncolumn 5 == \"station\")", fillcolor="#330000"];
  found [label="station-mode\ndevice found?", shape=diamond, fillcolor="#1a1608", color="#8a6a2f", fontcolor="#e0c896"];
  nodev [label="toast: \"No wireless\ndevice found\", exit 1", shape=doublecircle, fillcolor="#330000", penwidth=2, color="#ff2020", fontcolor="#ff8888"];

  toastscan [label="toast: \"Scanning for\nnetworks...\"\n(click gave no feedback\nuntil now)"];
  scan [label="iwctl station <iface> scan\n(async over D-Bus,\nreturns before results exist)\nsleep 3", fillcolor="#1a0000"];

  subgraph cluster_clean {
    label="get-networks -> bare SSID list"; style="rounded"; color="#555555"; fontcolor="white"; bgcolor="#0a0a0a";
    getnet [label="iwctl station <iface>\nget-networks\n(boxed table output)"];
    strip1 [label="strip ANSI escapes", fillcolor="#330000"];
    strip2 [label="drop first 4 lines\n(border+header+separator)", fillcolor="#330000"];
    strip3 [label="strip leading */>/space\n(known-network markers)", fillcolor="#330000"];
    strip4 [label="truncate at first\n2+-space gap\n(drops Security/Signal cols)", fillcolor="#330000"];
    getnet -> strip1 -> strip2 -> strip3 -> strip4;
  }

  picker [label="syn_pick::rofi SSID picker\n(720px, up to 15 visible,\nthemed from live SYN_* palette)", fillcolor="#4d0000", penwidth=2, color="#ff2020"];
  chosen [label="SSID chosen?", shape=diamond, fillcolor="#1a1608", color="#8a6a2f", fontcolor="#e0c896"];
  dismissed [label="picker dismissed,\nexit normally,\nno popup opens", shape=doublecircle, fillcolor="#330000", penwidth=2, color="#666"];

  popup [label="syn_popup::run:\nundecorated centered foot\n(app-id=syn-os-popup)", fillcolor="#1a0000"];
  connect [label="iwctl station <iface>\nconnect <ssid>\n(interactive passphrase\nprompt if secured)", fillcolor="#330000"];
  rc [label="exit code?", shape=diamond, fillcolor="#1a1608", color="#8a6a2f", fontcolor="#e0c896"];

  ok [label="popup closes itself\ntoast: \"Connected to <ssid>\"", shape=doublecircle, fillcolor="#4d0000", penwidth=2, color="#ff2020"];
  bad [label="popup waits for keypress\n(error stays visible)\ntoast (critical): \"Failed\nto connect to <ssid>\"", shape=doublecircle, fillcolor="#330000", penwidth=2, color="#ff2020", fontcolor="#ff8888"];

  click -> device -> found;
  found -> nodev [label=" no"];
  found -> toastscan [label=" yes"];
  toastscan -> scan -> getnet;
  strip4 -> picker -> chosen;
  chosen -> dismissed [label=" no"];
  chosen -> popup [label=" yes"];
  popup -> connect -> rc;
  rc -> ok [label=" 0"];
  rc -> bad [label=" nonzero"];

  note [shape=note, fillcolor="#1a1608", color="#665522", fontcolor="#ccaa66",
        label="No NetworkManager applet, no standalone wifi GUI.\nOne script drives iwd directly through iwctl --\nno intermediate daemon or config file of its own."];
}
