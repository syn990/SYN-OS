digraph philosophy {
  rankdir=LR;
  bgcolor="#000000";
  fontname="monospace";
  node [shape=box, style="rounded,filled", fillcolor="#2c0101", color="#800000", fontcolor="white", fontname="monospace", fontsize=10];
  edge [color="#AAAAAA", fontcolor="white", fontname="monospace", fontsize=9];

  label="If something behaves oddly, here's where the file that caused it lives";
  labelloc="t"; fontsize=14; fontcolor="#e8b4b4";

  question [label="\"Why does my\nsystem do that?\"", shape=oval, fillcolor="#400101"];

  pkg [label="A package is installed\n(or isn't)", fillcolor="#260101"];
  pkg_src [label="syn-packages.zsh\n7 commented arrays,\nsee Package Collection", shape=note, fillcolor="#1a1608", color="#8a6a2f", fontcolor="#e0c896"];

  cfg [label="A config file looks\na certain way", fillcolor="#260101"];
  cfg_src [label="DotfileOverlay/\nthe actual file, not a\ntemplate, see Dotfile Overlay", shape=note, fillcolor="#1a1608", color="#8a6a2f", fontcolor="#e0c896"];

  install [label="The install did\nsomething specific", fillcolor="#260101"];
  install_src [label="syn-stage0.zsh / syn-stage1.zsh\nnamed, sequential steps,\nsee How the Installer Works", shape=note, fillcolor="#1a1608", color="#8a6a2f", fontcolor="#e0c896"];

  history [label="\"Has this always\nbeen this way?\"", fillcolor="#260101"];
  history_src [label="docs/history.md\nreal diffs across both\nrepos back to 2021,\nnot a tidied-up summary", shape=note, fillcolor="#1a1608", color="#8a6a2f", fontcolor="#e0c896"];

  question -> pkg -> pkg_src;
  question -> cfg -> cfg_src;
  question -> install -> install_src;
  question -> history -> history_src;

  note [shape=note, fillcolor="#1a1608", color="#665522", fontcolor="#ccaa66",
        label="No layer requires trusting a summary someone\nwrote about the system. Every arrow above\nends at a real file you can open."];
}
